# ==========================================
# 文件服务器配置
# ==========================================
PORT=3000
FILE_SERVER_URL=http://localhost:3000

# ==========================================
# 阿里云 OSS 配置
# ==========================================
OSS_REGION=oss-cn-hangzhou
OSS_ACCESS_KEY_ID=your_access_key_id
OSS_ACCESS_KEY_SECRET=your_access_key_secret
OSS_BUCKET=my-openclaw-files

# ==========================================
# 文件上传限制
# ==========================================
MAX_FILE_SIZE=10485760        # 10MB (bytes)
UPLOAD_RATE_LIMIT=10          # 每分钟最多上传次数
ALLOWED_FILE_TYPES=pdf,doc,docx,xls,xlsx,txt,csv,md,jpg,jpeg,png,gif,webp

# ==========================================
# 文件生命周期
# ==========================================
FILE_RETENTION_DAYS=7         # 文件保留天数（自动删除）

# ==========================================
# 安全配置
# ==========================================
CORS_ORIGIN=*                 # CORS 允许的来源（* = 所有）
ENABLE_RATE_LIMIT=true        # 是否启用速率限制
